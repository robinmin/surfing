{
    "extends": "astro/tsconfigs/base",
    "compilerOptions": {
        "strictNullChecks": true,
        "allowJs": true,
        "baseUrl": ".",
        "paths": {
            "~/*": ["src/*"],
            "@turnstile/client": ["../turnstile/packages/client/src/index.ts"],
            "@turnstile/client/*": ["../turnstile/packages/client/src/*"],
            "@turnstile/api-client-core": ["../turnstile/packages/api-client-core/src/index.ts"],
            "@turnstile/api-client-core/*": ["../turnstile/packages/api-client-core/src/*"]
        }
    },
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist/", "vendor/turnstile-api/**"]
}
